<%- include('../partials/header') %>

<div class="page-header">
    <div>
        <h1 class="page-title">
            <i class="fas fa-crown"></i>
            Admin Dashboard
        </h1>
        <p class="page-subtitle">System overview and management</p>
    </div>
    <div class="page-actions">
        <button class="btn btn-secondary" onclick="refreshStats()">
            <i class="fas fa-sync-alt"></i>
            Refresh
        </button>
    </div>
</div>

<!-- Stats Grid with Enhanced Design -->
<div class="stats-grid" style="grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; margin-bottom: 32px;">
    <div class="stat-card" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border: none; color: white;">
        <div class="stat-icon" style="background: rgba(255, 255, 255, 0.2); color: white;">
            <i class="fas fa-users"></i>
        </div>
        <div class="stat-content">
            <div class="stat-label" style="color: rgba(255, 255, 255, 0.9);">Total Users</div>
            <div class="stat-value" style="color: white; font-size: 32px;"><%= stats.totalUsers %></div>
            <div style="margin-top: 8px; font-size: 13px; color: rgba(255, 255, 255, 0.8);">
                <i class="fas fa-user-plus"></i> Registered accounts
            </div>
        </div>
    </div>

    <div class="stat-card" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); border: none; color: white;">
        <div class="stat-icon" style="background: rgba(255, 255, 255, 0.2); color: white;">
            <i class="fas fa-server"></i>
        </div>
        <div class="stat-content">
            <div class="stat-label" style="color: rgba(255, 255, 255, 0.9);">Total Servers</div>
            <div class="stat-value" style="color: white; font-size: 32px;"><%= stats.totalServers %></div>
            <div style="margin-top: 8px; font-size: 13px; color: rgba(255, 255, 255, 0.8);">
                <i class="fas fa-database"></i> All server instances
            </div>
        </div>
    </div>

    <div class="stat-card" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); border: none; color: white;">
        <div class="stat-icon" style="background: rgba(255, 255, 255, 0.2); color: white;">
            <i class="fas fa-play-circle"></i>
        </div>
        <div class="stat-content">
            <div class="stat-label" style="color: rgba(255, 255, 255, 0.9);">Active Servers</div>
            <div class="stat-value" style="color: white; font-size: 32px;"><%= stats.activeServers %></div>
            <div style="margin-top: 8px; font-size: 13px; color: rgba(255, 255, 255, 0.8);">
                <i class="fas fa-bolt"></i> Currently running
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions with Modern Cards -->
<div class="section-header" style="margin-bottom: 20px;">
    <h2 style="font-size: 20px; font-weight: 700; color: var(--text-primary); display: flex; align-items: center; gap: 10px;">
        <i class="fas fa-bolt" style="color: var(--accent-primary);"></i>
        Quick Actions
    </h2>
</div>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 32px;">
    <a href="/admin/users" class="action-card" style="background: var(--bg-card); border: 1px solid var(--border-primary); border-radius: 16px; padding: 24px; text-decoration: none; transition: all 0.2s; display: flex; flex-direction: column; align-items: center; gap: 12px; text-align: center;">
        <div style="width: 56px; height: 56px; border-radius: 14px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); display: flex; align-items: center; justify-content: center; color: white; font-size: 24px;">
            <i class="fas fa-users-cog"></i>
        </div>
        <span style="font-weight: 600; color: var(--text-primary); font-size: 15px;">Manage Users</span>
        <span style="font-size: 12px; color: var(--text-muted);">View and edit users</span>
    </a>
    
    <a href="/admin/servers/create" class="action-card" style="background: var(--bg-card); border: 1px solid var(--border-primary); border-radius: 16px; padding: 24px; text-decoration: none; transition: all 0.2s; display: flex; flex-direction: column; align-items: center; gap: 12px; text-align: center;">
        <div style="width: 56px; height: 56px; border-radius: 14px; background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); display: flex; align-items: center; justify-content: center; color: white; font-size: 24px;">
            <i class="fas fa-plus-circle"></i>
        </div>
        <span style="font-weight: 600; color: var(--text-primary); font-size: 15px;">Create Server</span>
        <span style="font-size: 12px; color: var(--text-muted);">Add new server</span>
    </a>
    
    <a href="/admin/servers" class="action-card" style="background: var(--bg-card); border: 1px solid var(--border-primary); border-radius: 16px; padding: 24px; text-decoration: none; transition: all 0.2s; display: flex; flex-direction: column; align-items: center; gap: 12px; text-align: center;">
        <div style="width: 56px; height: 56px; border-radius: 14px; background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); display: flex; align-items: center; justify-content: center; color: white; font-size: 24px;">
            <i class="fas fa-server"></i>
        </div>
        <span style="font-weight: 600; color: var(--text-primary); font-size: 15px;">View Servers</span>
        <span style="font-size: 12px; color: var(--text-muted);">Manage all servers</span>
    </a>
    
    <a href="/admin/settings" class="action-card" style="background: var(--bg-card); border: 1px solid var(--border-primary); border-radius: 16px; padding: 24px; text-decoration: none; transition: all 0.2s; display: flex; flex-direction: column; align-items: center; gap: 12px; text-align: center;">
        <div style="width: 56px; height: 56px; border-radius: 14px; background: linear-gradient(135deg, #fa709a 0%, #fee140 100%); display: flex; align-items: center; justify-content: center; color: white; font-size: 24px;">
            <i class="fas fa-cog"></i>
        </div>
        <span style="font-weight: 600; color: var(--text-primary); font-size: 15px;">Panel Settings</span>
        <span style="font-size: 12px; color: var(--text-muted);">Configure panel</span>
    </a>
</div>

<style>
.action-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
    border-color: var(--accent-primary);
}
</style>

<!-- Recent Activity -->
<div class="row">
    <div class="col-6">
        <div class="card">
            <div class="card-header" style="display: flex; align-items: center; justify-content: space-between;">
                <h3 style="display: flex; align-items: center; gap: 10px;">
                    <i class="fas fa-users" style="color: var(--accent-primary);"></i>
                    Recent Users
                </h3>
                <a href="/admin/users" class="btn btn-sm btn-secondary">
                    <i class="fas fa-arrow-right"></i>
                    View All
                </a>
            </div>
            <div class="table-container">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Username</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (users && users.length > 0) { %>
                            <% users.slice(0, 5).forEach(user => { %>
                                <tr>
                                    <td>
                                        <div style="display: flex; align-items: center; gap: 10px;">
                                            <div style="width: 32px; height: 32px; border-radius: 50%; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); display: flex; align-items: center; justify-content: center; color: white; font-weight: 600; font-size: 12px;">
                                                <%= user.username.charAt(0).toUpperCase() %>
                                            </div>
                                            <span style="font-weight: 500;"><%= user.username %></span>
                                        </div>
                                    </td>
                                    <td style="color: var(--text-secondary);"><%= user.email %></td>
                                    <td>
                                        <span class="badge <%= user.role === 'admin' ? 'badge-warning' : 'badge-info' %>">
                                            <i class="fas fa-<%= user.role === 'admin' ? 'crown' : 'user' %>"></i>
                                            <%= user.role %>
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge <%= user.status === 'active' ? 'badge-success' : 'badge-danger' %>">
                                            <i class="fas fa-circle" style="font-size: 8px;"></i>
                                            <%= user.status %>
                                        </span>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="4" style="text-align: center; padding: 32px; color: var(--text-muted);">
                                    <i class="fas fa-users" style="font-size: 48px; opacity: 0.3; margin-bottom: 12px;"></i>
                                    <div>No users found</div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-6">
        <div class="card">
            <div class="card-header" style="display: flex; align-items: center; justify-content: space-between;">
                <h3 style="display: flex; align-items: center; gap: 10px;">
                    <i class="fas fa-server" style="color: var(--accent-primary);"></i>
                    Recent Servers
                </h3>
                <a href="/admin/servers" class="btn btn-sm btn-secondary">
                    <i class="fas fa-arrow-right"></i>
                    View All
                </a>
            </div>
            <div class="table-container">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Owner</th>
                            <th>Status</th>
                            <th>Port</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (servers && servers.length > 0) { %>
                            <% servers.slice(0, 5).forEach(server => { %>
                                <tr>
                                    <td>
                                        <div style="display: flex; align-items: center; gap: 10px;">
                                            <i class="fas fa-server" style="color: var(--accent-primary);"></i>
                                            <span style="font-weight: 500;"><%= server.name %></span>
                                        </div>
                                    </td>
                                    <td style="color: var(--text-secondary);">
                                        <%= users.find(u => u.id === server.owner_id)?.username || 'Unknown' %>
                                    </td>
                                    <td>
                                        <span class="badge <%= server.status === 'running' ? 'badge-success' : 'badge-danger' %>">
                                            <i class="fas fa-circle" style="font-size: 8px;"></i>
                                            <%= server.status %>
                                        </span>
                                    </td>
                                    <td>
                                        <code style="background: var(--bg-tertiary); padding: 4px 8px; border-radius: 6px; font-size: 12px;">
                                            <%= server.port %>
                                        </code>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="4" style="text-align: center; padding: 32px; color: var(--text-muted);">
                                    <i class="fas fa-server" style="font-size: 48px; opacity: 0.3; margin-bottom: 12px;"></i>
                                    <div>No servers found</div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- System Information with Enhanced Design -->
<div class="card">
    <div class="card-header" style="display: flex; align-items: center; justify-content: space-between;">
        <h3 style="display: flex; align-items: center; gap: 10px;">
            <i class="fas fa-info-circle" style="color: var(--accent-primary);"></i>
            System Information
        </h3>
        <span class="badge badge-success">
            <i class="fas fa-check-circle"></i>
            Healthy
        </span>
    </div>
    <div class="card-body">
        <div class="system-info-grid" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px;">
            <div class="info-item" style="background: var(--bg-tertiary); padding: 16px; border-radius: 12px; border: 1px solid var(--border-primary);">
                <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 8px;">
                    <i class="fab fa-node-js" style="color: #68a063; font-size: 20px;"></i>
                    <span class="info-label" style="font-weight: 600;">Node Version</span>
                </div>
                <span class="info-value" style="font-size: 18px; color: var(--text-primary);"><%= systemInfo.nodeVersion %></span>
            </div>
            <div class="info-item" style="background: var(--bg-tertiary); padding: 16px; border-radius: 12px; border: 1px solid var(--border-primary);">
                <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 8px;">
                    <i class="fas fa-desktop" style="color: var(--accent-primary); font-size: 20px;"></i>
                    <span class="info-label" style="font-weight: 600;">Platform</span>
                </div>
                <span class="info-value" style="font-size: 18px; color: var(--text-primary);"><%= systemInfo.platform %></span>
            </div>
            <div class="info-item" style="background: var(--bg-tertiary); padding: 16px; border-radius: 12px; border: 1px solid var(--border-primary);">
                <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 8px;">
                    <i class="fas fa-microchip" style="color: var(--info); font-size: 20px;"></i>
                    <span class="info-label" style="font-weight: 600;">CPU Cores</span>
                </div>
                <span class="info-value" style="font-size: 18px; color: var(--text-primary);"><%= systemInfo.cpuCores %></span>
            </div>
            <div class="info-item" style="background: var(--bg-tertiary); padding: 16px; border-radius: 12px; border: 1px solid var(--border-primary);">
                <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 8px;">
                    <i class="fas fa-memory" style="color: var(--warning); font-size: 20px;"></i>
                    <span class="info-label" style="font-weight: 600;">Total Memory</span>
                </div>
                <span class="info-value" style="font-size: 18px; color: var(--text-primary);"><%= systemInfo.totalMemory %></span>
            </div>
            <div class="info-item" style="background: var(--bg-tertiary); padding: 16px; border-radius: 12px; border: 1px solid var(--border-primary);">
                <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 8px;">
                    <i class="fas fa-memory" style="color: var(--success); font-size: 20px;"></i>
                    <span class="info-label" style="font-weight: 600;">Free Memory</span>
                </div>
                <span class="info-value" style="font-size: 18px; color: var(--text-primary);"><%= systemInfo.freeMemory %></span>
            </div>
            <div class="info-item" style="background: var(--bg-tertiary); padding: 16px; border-radius: 12px; border: 1px solid var(--border-primary);">
                <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 8px;">
                    <i class="fas fa-clock" style="color: var(--accent-primary); font-size: 20px;"></i>
                    <span class="info-label" style="font-weight: 600;">System Uptime</span>
                </div>
                <span class="info-value" style="font-size: 18px; color: var(--text-primary);" id="systemUptime">
                    <i class="fas fa-spinner fa-spin"></i>
                </span>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>

<script>
// Wait for DOM to be fully loaded
document.addEventListener('DOMContentLoaded', function() {
    // Calculate and display system uptime
    function formatSystemUptime() {
        const systemUptimeSeconds = <%= systemInfo.uptime %>;
        const days = Math.floor(systemUptimeSeconds / 86400);
        const hours = Math.floor((systemUptimeSeconds % 86400) / 3600);
        const minutes = Math.floor((systemUptimeSeconds % 3600) / 60);
        
        let uptimeText = '';
        if (days > 0) uptimeText += `${days}d `;
        if (hours > 0) uptimeText += `${hours}h `;
        uptimeText += `${minutes}m`;
        
        const uptimeEl = document.getElementById('systemUptime');
        if (uptimeEl) {
            uptimeEl.textContent = uptimeText.trim();
        }
    }

    // Initialize
    formatSystemUptime();
});

// Refresh stats (global function)
function refreshStats() {
    const btn = event.target.closest('button');
    const icon = btn.querySelector('i');
    icon.classList.add('fa-spin');
    
    setTimeout(() => {
        location.reload();
    }, 500);
}

// Show toast notification (global function)
function showToast(message, type = 'success') {
    const toast = document.createElement('div');
    toast.className = `alert alert-${type}`;
    toast.style.cssText = 'position: fixed; top: 20px; right: 20px; z-index: 9999; animation: slideInRight 0.3s ease;';
    toast.innerHTML = `
        <i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-circle'}"></i>
        <span>${message}</span>
    `;
    document.body.appendChild(toast);
    
    setTimeout(() => {
        toast.style.animation = 'slideOutRight 0.3s ease';
        setTimeout(() => toast.remove(), 300);
    }, 3000);
}

// Add animation keyframes
const style = document.createElement('style');
style.textContent = `
    @keyframes slideInRight {
        from { transform: translateX(100%); opacity: 0; }
        to { transform: translateX(0); opacity: 1; }
    }
    @keyframes slideOutRight {
        from { transform: translateX(0); opacity: 1; }
        to { transform: translateX(100%); opacity: 0; }
    }
`;
document.head.appendChild(style);
</script>
