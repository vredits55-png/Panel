<%- include('partials/header') %>

<div class="page-header">
    <div>
        <h1 class="page-title">
            <i class="fas fa-home"></i>
            Dashboard
        </h1>
        <p class="page-subtitle">Welcome back, <%= user.username %>! Here's your server overview.</p>
    </div>
    <% if (user.role === 'admin') { %>
        <a href="/admin/servers/create" class="btn btn-primary">
            <i class="fas fa-plus"></i>
            Create Server
        </a>
    <% } %>
</div>

<!-- Stats Overview -->
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon primary">
            <i class="fas fa-server"></i>
        </div>
        <div class="stat-content">
            <div class="stat-label">Total Servers</div>
            <div class="stat-value"><%= servers.length %></div>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon success">
            <i class="fas fa-circle-check"></i>
        </div>
        <div class="stat-content">
            <div class="stat-label">Online</div>
            <div class="stat-value"><%= servers.filter(s => s.status === 'running').length %></div>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon danger">
            <i class="fas fa-circle-xmark"></i>
        </div>
        <div class="stat-content">
            <div class="stat-label">Offline</div>
            <div class="stat-value"><%= servers.filter(s => s.status === 'stopped').length %></div>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon warning">
            <i class="fas fa-users"></i>
        </div>
        <div class="stat-content">
            <div class="stat-label">Players Online</div>
            <div class="stat-value"><%= Object.values(onlinePlayers || {}).reduce((acc, curr) => acc + (curr.length || 0), 0) %></div>
        </div>
    </div>
</div>

<!-- Servers Section -->
<div class="section-header">
    <h2 class="section-title">
        <i class="fas fa-server"></i>
        Your Servers
    </h2>
    <% if (servers.length > 0) { %>
        <div class="section-actions">
            <button class="btn btn-secondary btn-sm" onclick="refreshAllStats()">
                <i class="fas fa-sync-alt"></i>
                Refresh Stats
            </button>
        </div>
    <% } %>
</div>

<% if (servers.length === 0) { %>
    <div class="empty-state">
        <i class="fas fa-server"></i>
        <h3>No Servers Yet</h3>
        <p>You don't have any servers assigned. Contact an administrator or create one if you're an admin.</p>
        <% if (user.role === 'admin') { %>
            <a href="/admin/servers/create" class="btn btn-primary">
                <i class="fas fa-plus"></i>
                Create Your First Server
            </a>
        <% } %>
    </div>
<% } else { %>
    <div class="modern-server-grid">
        <% servers.forEach(server => { %>
            <div class="modern-server-card" data-server-id="<%= server.id %>">
                <!-- Card Header -->
                <div class="modern-server-header">
                    <div class="server-title-section">
                        <div class="server-icon-wrapper">
                            <i class="fas fa-cube"></i>
                        </div>
                        <div class="server-title-info">
                            <h3 class="server-title"><%= server.name %></h3>
                            <div class="server-badges">
                                <span class="badge badge-info"><%= server.server_type || 'Minecraft' %></span>
                                <span class="badge badge-secondary"><%= server.version || 'Latest' %></span>
                                <% if (server.is_owner === 0) { %>
                                    <span class="badge badge-warning" title="You are a subuser on this server">
                                        <i class="fas fa-user-friends"></i> Subuser
                                    </span>
                                <% } %>
                            </div>
                        </div>
                    </div>
                    <div class="server-status-badge">
                        <span class="status-badge <%= server.status === 'running' ? 'online' : 'offline' %>">
                            <span class="status-dot"></span>
                            <%= server.status === 'running' ? 'Online' : 'Offline' %>
                        </span>
                    </div>
                </div>

                <!-- Live Stats Section -->
                <div class="server-live-stats">
                    <div class="live-stat-item">
                        <div class="live-stat-header">
                            <i class="fas fa-microchip"></i>
                            <span>CPU</span>
                        </div>
                        <div class="live-stat-value" id="cpu-<%= server.id %>">
                            <% if (server.status === 'running') { %>
                                <span class="loading-stat">--</span>
                            <% } else { %>
                                <span class="offline-stat">0%</span>
                            <% } %>
                        </div>
                        <div class="progress">
                            <div class="progress-bar" id="cpu-bar-<%= server.id %>" style="width: 0%"></div>
                        </div>
                    </div>

                    <div class="live-stat-item">
                        <div class="live-stat-header">
                            <i class="fas fa-memory"></i>
                            <span>RAM</span>
                        </div>
                        <div class="live-stat-value" id="ram-<%= server.id %>">
                            <% if (server.status === 'running') { %>
                                <span class="loading-stat">--</span>
                            <% } else { %>
                                <span class="offline-stat">0 MB</span>
                            <% } %>
                        </div>
                        <div class="progress">
                            <div class="progress-bar" id="ram-bar-<%= server.id %>" style="width: 0%"></div>
                        </div>
                    </div>

                    <div class="live-stat-item">
                        <div class="live-stat-header">
                            <i class="fas fa-hdd"></i>
                            <span>Disk</span>
                        </div>
                        <div class="live-stat-value" id="disk-<%= server.id %>">
                            <% if (server.status === 'running') { %>
                                <span class="loading-stat">--</span>
                            <% } else { %>
                                <span class="offline-stat">0 MB</span>
                            <% } %>
                        </div>
                        <div class="progress">
                            <div class="progress-bar warning" id="disk-bar-<%= server.id %>" style="width: 0%"></div>
                        </div>
                    </div>
                </div>

                <!-- Server Info -->
                <div class="server-info-grid">
                    <div class="info-item">
                        <i class="fas fa-network-wired"></i>
                        <span>Port: <%= server.port %></span>
                    </div>
                    <div class="info-item">
                        <i class="fas fa-users"></i>
                        <span id="players-<%= server.id %>"><%= (onlinePlayers[server.id] || []).length %> Players</span>
                    </div>
                    <div class="info-item">
                        <i class="fas fa-clock"></i>
                        <span id="uptime-<%= server.id %>">
                            <% if (server.status === 'running') { %>
                                Calculating...
                            <% } else { %>
                                Offline
                            <% } %>
                        </span>
                    </div>
                    <div class="info-item">
                        <i class="fas fa-memory"></i>
                        <span><%= server.ram %> MB Allocated</span>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="server-actions">
                    <button class="action-btn primary" onclick="window.location.href='/servers/<%= server.id %>/dashboard'">
                        <i class="fas fa-chart-line"></i>
                        <span>Manage</span>
                    </button>
                    <button class="action-btn success" 
                            onclick="controlServer(<%= server.id %>, 'start')" 
                            <%= server.status === 'running' ? 'disabled' : '' %>>
                        <i class="fas fa-play"></i>
                        <span>Start</span>
                    </button>
                    <button class="action-btn danger" 
                            onclick="controlServer(<%= server.id %>, 'stop')" 
                            <%= server.status !== 'running' ? 'disabled' : '' %>>
                        <i class="fas fa-stop"></i>
                        <span>Stop</span>
                    </button>
                    <button class="action-btn warning" 
                            onclick="controlServer(<%= server.id %>, 'restart')" 
                            <%= server.status !== 'running' ? 'disabled' : '' %>>
                        <i class="fas fa-sync-alt"></i>
                        <span>Restart</span>
                    </button>
                </div>
            </div>
        <% }) %>
    </div>
<% } %>

<style>
/* Section Header */
.section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin: 48px 0 24px;
    padding-top: 32px;
    border-top: 1px solid var(--border-primary);
}

.section-title {
    font-size: 24px;
    font-weight: 700;
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 0;
}

.section-title i {
    color: var(--accent-primary);
}

.section-actions {
    display: flex;
    gap: 12px;
}

.btn-sm {
    padding: 8px 16px;
    font-size: 13px;
}

/* Modern Server Grid */
.modern-server-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
    gap: 24px;
}

/* Modern Server Card */
.modern-server-card {
    background: var(--bg-card);
    border: 1px solid var(--border-primary);
    border-radius: 16px;
    overflow: hidden;
    transition: all var(--transition-base);
}

.modern-server-card:hover {
    border-color: var(--accent-primary);
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
}

/* Card Header */
.modern-server-header {
    padding: 20px;
    border-bottom: 1px solid var(--border-primary);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
}

.server-title-section {
    display: flex;
    align-items: center;
    gap: 14px;
    flex: 1;
    min-width: 0;
}

.server-icon-wrapper {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: var(--accent-glow);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    color: var(--accent-primary);
    flex-shrink: 0;
}

.server-title-info {
    flex: 1;
    min-width: 0;
}

.server-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 6px 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.server-badges {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
}

.server-status-badge {
    flex-shrink: 0;
}

/* Live Stats Section */
.server-live-stats {
    padding: 20px;
    background: var(--bg-tertiary);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
}

.live-stat-item {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.live-stat-header {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.live-stat-header i {
    font-size: 14px;
}

.live-stat-value {
    font-size: 20px;
    font-weight: 800;
    color: var(--text-primary);
    line-height: 1;
}

.loading-stat {
    color: var(--text-muted);
    animation: pulse 1.5s infinite;
}

.offline-stat {
    color: var(--text-muted);
}

@keyframes pulse {
    0%, 100% {
        opacity: 1;
    }
    50% {
        opacity: 0.5;
    }
}

/* Server Info Grid */
.server-info-grid {
    padding: 20px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
}

.info-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text-secondary);
    font-weight: 500;
}

.info-item i {
    width: 16px;
    color: var(--accent-primary);
    font-size: 14px;
}

/* Action Buttons */
.server-actions {
    padding: 16px 20px;
    border-top: 1px solid var(--border-primary);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
}

.action-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 12px 8px;
    border: 1px solid var(--border-primary);
    border-radius: 10px;
    background: transparent;
    color: var(--text-secondary);
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition-fast);
}

.action-btn i {
    font-size: 18px;
}

.action-btn:hover:not(:disabled) {
    transform: translateY(-2px);
}

.action-btn.primary:hover:not(:disabled) {
    background: var(--accent-glow);
    border-color: var(--accent-primary);
    color: var(--accent-primary);
}

.action-btn.success:hover:not(:disabled) {
    background: var(--success-glow);
    border-color: var(--success);
    color: var(--success);
}

.action-btn.danger:hover:not(:disabled) {
    background: var(--danger-glow);
    border-color: var(--danger);
    color: var(--danger);
}

.action-btn.warning:hover:not(:disabled) {
    background: var(--warning-glow);
    border-color: var(--warning);
    color: var(--warning);
}

.action-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
}

/* Responsive */
@media (max-width: 1200px) {
    .modern-server-grid {
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    }
}

@media (max-width: 768px) {
    .modern-server-grid {
        grid-template-columns: 1fr;
    }

    .server-live-stats {
        grid-template-columns: 1fr;
    }

    .server-info-grid {
        grid-template-columns: 1fr;
    }

    .server-actions {
        grid-template-columns: repeat(2, 1fr);
    }

    .section-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 16px;
    }
}
</style>

<script>
// Server control function
function controlServer(serverId, action) {
    const actionName = action === 'start' ? 'start' : action === 'stop' ? 'stop' : 'restart';
    
    if (!confirm(`Are you sure you want to ${actionName} this server?`)) return;

    const card = document.querySelector(`[data-server-id="${serverId}"]`);
    if (card) {
        card.style.opacity = '0.6';
        card.style.pointerEvents = 'none';
    }

    fetch(`/servers/${serverId}/${action}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            showToast(`Server ${actionName} command sent successfully!`, 'success');
            setTimeout(() => location.reload(), 1500);
        } else {
            showToast(`Failed to ${actionName} server: ${data.error || 'Unknown error'}`, 'error');
            if (card) {
                card.style.opacity = '1';
                card.style.pointerEvents = 'auto';
            }
        }
    })
    .catch(error => {
        console.error('Error:', error);
        showToast('An error occurred while communicating with the server.', 'error');
        if (card) {
            card.style.opacity = '1';
            card.style.pointerEvents = 'auto';
        }
    });
}

// Live stats update
function updateLiveStats() {
    <% servers.forEach(server => { %>
        <% if (server.status === 'running') { %>
            fetch('/servers/<%= server.id %>/stats')
                .then(res => res.json())
                .then(data => {
                    if (data.success && data.stats) {
                        // CPU
                        const cpuEl = document.getElementById('cpu-<%= server.id %>');
                        const cpuBar = document.getElementById('cpu-bar-<%= server.id %>');
                        if (cpuEl && data.stats.cpu !== undefined) {
                            const cpuPercent = Math.round(data.stats.cpu);
                            cpuEl.innerHTML = `<span style="color: ${cpuPercent > 80 ? 'var(--danger)' : cpuPercent > 60 ? 'var(--warning)' : 'var(--success)'}">${cpuPercent}%</span>`;
                            if (cpuBar) {
                                cpuBar.style.width = cpuPercent + '%';
                                cpuBar.className = 'progress-bar' + (cpuPercent > 80 ? ' danger' : cpuPercent > 60 ? ' warning' : '');
                            }
                        }

                        // RAM
                        const ramEl = document.getElementById('ram-<%= server.id %>');
                        const ramBar = document.getElementById('ram-bar-<%= server.id %>');
                        if (ramEl && data.stats.memory !== undefined) {
                            const ramUsed = Math.round(data.stats.memory / 1024 / 1024);
                            const ramTotal = <%= server.ram %>;
                            const ramPercent = Math.round((ramUsed / ramTotal) * 100);
                            ramEl.innerHTML = `<span style="color: ${ramPercent > 80 ? 'var(--danger)' : ramPercent > 60 ? 'var(--warning)' : 'var(--success)'}">${ramUsed} MB</span>`;
                            if (ramBar) {
                                ramBar.style.width = ramPercent + '%';
                                ramBar.className = 'progress-bar' + (ramPercent > 80 ? ' danger' : ramPercent > 60 ? ' warning' : '');
                            }
                        }

                        // Disk
                        const diskEl = document.getElementById('disk-<%= server.id %>');
                        const diskBar = document.getElementById('disk-bar-<%= server.id %>');
                        if (diskEl && data.stats.disk !== undefined) {
                            const diskMB = Math.round(data.stats.disk / 1024 / 1024);
                            diskEl.innerHTML = `<span style="color: var(--warning)">${diskMB} MB</span>`;
                            if (diskBar) {
                                const diskPercent = Math.min(100, Math.round((diskMB / 10000) * 100));
                                diskBar.style.width = diskPercent + '%';
                            }
                        }

                        // Uptime
                        const uptimeEl = document.getElementById('uptime-<%= server.id %>');
                        if (uptimeEl && data.stats.uptime !== undefined) {
                            uptimeEl.textContent = formatUptime(data.stats.uptime);
                        }

                        // Players
                        const playersEl = document.getElementById('players-<%= server.id %>');
                        if (playersEl && data.stats.players !== undefined) {
                            playersEl.textContent = `${data.stats.players} Players`;
                        }
                    }
                })
                .catch(err => console.error('Stats error for server <%= server.id %>:', err));
        <% } %>
    <% }) %>
}

// Format uptime
function formatUptime(seconds) {
    const days = Math.floor(seconds / 86400);
    const hours = Math.floor((seconds % 86400) / 3600);
    const minutes = Math.floor((seconds % 3600) / 60);
    
    if (days > 0) return `${days}d ${hours}h`;
    if (hours > 0) return `${hours}h ${minutes}m`;
    return `${minutes}m`;
}

// Refresh all stats
function refreshAllStats() {
    showToast('Refreshing server statistics...', 'info');
    updateLiveStats();
}

// Toast notification
function showToast(message, type = 'success') {
    const toast = document.createElement('div');
    toast.className = `alert alert-${type}`;
    const icon = type === 'success' ? 'check-circle' : type === 'error' ? 'exclamation-circle' : 'info-circle';
    toast.innerHTML = `
        <i class="fas fa-${icon}"></i>
        <span>${message}</span>
        <button class="alert-close" onclick="this.parentElement.remove()">×</button>
    `;
    
    const container = document.querySelector('.page-container');
    container.insertBefore(toast, container.firstChild);
    
    setTimeout(() => {
        if (toast.parentElement) {
            toast.style.opacity = '0';
            toast.style.transform = 'translateY(-10px)';
            setTimeout(() => toast.remove(), 300);
        }
    }, 5000);
}

// Initialize
document.addEventListener('DOMContentLoaded', function() {
    // Update stats immediately
    updateLiveStats();
    
    // Update stats every 5 seconds
    setInterval(updateLiveStats, 5000);
});

// Re-initialize UI effects
if (typeof window.reinitializeUI === 'function') {
    window.reinitializeUI();
}
</script>

<%- include('partials/footer') %>
