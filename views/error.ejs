<%- include('partials/header') %>

<div class="error-page">
    <div class="error-container">
        <div class="error-icon">
            <i class="fas fa-exclamation-triangle"></i>
        </div>
        <h1 class="error-code"><%= status || 500 %></h1>
        <h2 class="error-message"><%= message || 'An error occurred' %></h2>
        
        <% if (typeof error !== 'undefined' && error && process.env.NODE_ENV === 'development') { %>
            <div class="error-details">
                <h3>Error Details (Development Mode)</h3>
                <pre><%= error.stack %></pre>
            </div>
        <% } %>

        <div class="error-actions">
            <a href="/dashboard" class="btn btn-primary">
                <i class="fas fa-home"></i>
                Go to Dashboard
            </a>
            <button onclick="history.back()" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i>
                Go Back
            </button>
        </div>
    </div>
</div>

<style>
    .error-page {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 60vh;
        padding: 40px 20px;
    }

    .error-container {
        text-align: center;
        max-width: 600px;
    }

    .error-icon {
        font-size: 80px;
        color: #e63946;
        margin-bottom: 20px;
        animation: pulse 2s infinite;
    }

    @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
    }

    .error-code {
        font-size: 72px;
        font-weight: 700;
        color: #e3e5e8;
        margin-bottom: 16px;
    }

    .error-message {
        font-size: 24px;
        color: #9aa1b0;
        margin-bottom: 32px;
    }

    .error-details {
        background: #1a1d24;
        border: 1px solid #23262e;
        border-radius: 12px;
        padding: 20px;
        margin: 32px 0;
        text-align: left;
    }

    .error-details h3 {
        color: #e3e5e8;
        margin-bottom: 12px;
    }

    .error-details pre {
        color: #9aa1b0;
        font-size: 12px;
        overflow-x: auto;
        white-space: pre-wrap;
        word-wrap: break-word;
    }

    .error-actions {
        display: flex;
        gap: 12px;
        justify-content: center;
        flex-wrap: wrap;
    }

    @media (max-width: 768px) {
        .error-code {
            font-size: 48px;
        }

        .error-message {
            font-size: 18px;
        }

        .error-icon {
            font-size: 60px;
        }
    }
</style>

<%- include('partials/footer') %>
