// Simple modal function
function showModal(title, content) {
    const modal = document.createElement('div');
    modal.style.cssText = `
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.8);
        z-index: 10000;
        display: flex;
        align-items: center;
        justify-content: center;
        animation: fadeIn 0.3s ease;
    `;
    
    modal.innerHTML = `
        <div style="
            background: var(--bg-primary);
            border-radius: 12px;
            padding: 24px;
            max-width: 600px;
            max-height: 80vh;
            overflow-y: auto;
            box-shadow: 0 20px 60px rgba(0,0,0,0.5);
        ">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <h2 style="margin: 0; color: var(--text-primary);">${title}</h2>
                <button onclick="this.closest('.modal').remove()" style="
                    background: none;
                    border: none;
                    font-size: 24px;
                    cursor: pointer;
                    color: var(--text-muted);
                ">×</button>
            </div>
            <div style="color: var(--text-secondary);">${content}</div>
        </div>
    `;
    
    modal.className = 'modal';
    document.body.appendChild(modal);
    
    modal.addEventListener('click', (e) => {
        if (e.target === modal) modal.remove();
    });
}

// Initialize software info on page load
document.addEventListener('DOMContentLoaded', function() {
    updateSoftwareInfo('<%= server.server_type || "vanilla" %>');
});

// ================================================
// ENHANCED VERSION MANAGEMENT SYSTEM
// ================================================

// Version mode management
let currentVersionMode = 'preset';
let customVersionValid = false;

// Toggle between preset and custom version modes
function toggleVersionMode(mode) {
    currentVersionMode = mode;
    
    const presetContainer = document.getElementById('presetVersionContainer');
    const customContainer = document.getElementById('customVersionContainer');
    const presetBtn = document.getElementById('presetModeBtn');
    const customBtn = document.getElementById('customModeBtn');
    
    if (mode === 'preset') {
        presetContainer.style.display = 'block';
        customContainer.style.display = 'none';
        presetBtn.classList.add('active');
        customBtn.classList.remove('active');
        
        // Enable preset select
        document.getElementById('versionSelect').required = true;
        document.getElementById('customVersionInput').required = false;
    } else {
        presetContainer.style.display = 'none';
        customContainer.style.display = 'block';
        presetBtn.classList.remove('active');
        customBtn.classList.add('active');
        
        // Enable custom input
        document.getElementById('versionSelect').required = false;
        document.getElementById('customVersionInput').required = true;
    }
}

// Validate custom version
async function validateCustomVersion() {
    const input = document.getElementById('customVersionInput');
    const feedback = document.getElementById('customVersionFeedback');
    const serverType = document.getElementById('serverTypeSelect').value;
    const version = input.value.trim();
    
    if (!version) {
        showVersionFeedback('error', 'Please enter a version');
        return;
    }
    
    // Show loading state
    showVersionFeedback('info', '<i class="fas fa-spinner fa-spin"></i> Validating version...');
    
    try {
        const response = await fetch('/servers/<%= server.id %>/settings/validate-version', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ version, serverType })
        });
        
        const data = await response.json();
        
        if (data.success) {
            if (data.valid) {
                customVersionValid = true;
                showVersionFeedback('success', `✅ ${data.message}`);
                input.style.borderColor = 'var(--success)';
            } else {
                customVersionValid = false;
                showVersionFeedback('error', `❌ ${data.message}`);
                input.style.borderColor = 'var(--danger)';
            }
        } else {
            customVersionValid = false;
            showVersionFeedback('error', '❌ Validation failed');
            input.style.borderColor = 'var(--danger)';
        }
    } catch (err) {
        console.error('Validation error:', err);
        customVersionValid = false;
        showVersionFeedback('error', '❌ Network error during validation');
        input.style.borderColor = 'var(--danger)';
    }
}

// Show version validation feedback
function showVersionFeedback(type, message) {
    const feedback = document.getElementById('customVersionFeedback');
    
    let className = 'alert alert-';
    if (type === 'success') className += 'success';
    else if (type === 'error') className += 'danger';
    else if (type === 'warning') className += 'warning';
    else className += 'info';
    
    feedback.innerHTML = `<div class="${className}" style="padding: 8px 12px; margin: 0; font-size: 13px;">${message}</div>`;
}

// Enhanced loadVersions function with complete version list
async function loadVersionsEnhanced() {
    const serverType = document.getElementById('serverTypeSelect').value;
    const versionSelect = document.getElementById('versionSelect');
    const versionCount = document.getElementById('versionCount');
    
    // Show loading state
    versionSelect.innerHTML = '<option>Loading versions...</option>';
    versionSelect.disabled = true;
    if (versionCount) versionCount.textContent = '...';
    
    try {
        const response = await fetch(`/servers/<%= server.id %>/settings/versions/${serverType}`);
        const data = await response.json();
        
        if (data.success && data.versions) {
            versionSelect.innerHTML = '';
            
            // Add current version first if not in list
            const currentVersion = '<%= server.version %>';
            if (!data.versions.includes(currentVersion)) {
                const currentOption = document.createElement('option');
                currentOption.value = currentVersion;
                currentOption.textContent = `${currentVersion} (Current)`;
                currentOption.selected = true;
                versionSelect.appendChild(currentOption);
            }
            
            // Add all available versions
            data.versions.forEach((version, index) => {
                const option = document.createElement('option');
                option.value = version;
                option.textContent = version;
                
                // Mark current version
                if (version === currentVersion) {
                    option.textContent += ' (Current)';
                    option.selected = true;
                }
                
                versionSelect.appendChild(option);
            });
            
            // Update version count
            if (versionCount) versionCount.textContent = data.versions.length;
            
            // Select the first version by default if current not found
            if (!data.versions.includes(currentVersion) && data.versions.length > 0) {
                versionSelect.selectedIndex = 1; // Skip current version option
            }
        } else {
            versionSelect.innerHTML = '<option>Error loading versions</option>';
            if (versionCount) versionCount.textContent = '0';
        }
    } catch (err) {
        console.error('Error loading versions:', err);
        versionSelect.innerHTML = '<option>Error loading versions</option>';
        if (versionCount) versionCount.textContent = '0';
    } finally {
        versionSelect.disabled = false;
    }
    
    // Update software info display
    updateSoftwareInfo(serverType);
}

// Initialize enhanced version system
document.addEventListener('DOMContentLoaded', function() {
    const customInput = document.getElementById('customVersionInput');
    if (customInput) {
        customInput.addEventListener('input', function() {
            const feedback = document.getElementById('customVersionFeedback');
            this.style.borderColor = '';
            if (feedback) feedback.innerHTML = '';
            customVersionValid = false;
        });
        
        // Validate on Enter key
        customInput.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                validateCustomVersion();
            }
        });
    }
    
    // Override the original functions if enhanced elements exist
    if (document.getElementById('customVersionContainer')) {
        // Replace the form onsubmit
        const form = document.querySelector('form[onsubmit*="changeSoftware"]');
        if (form) {
            form.onsubmit = changeSoftwareEnhanced;
        }
        
        // Replace the select onchange
        const select = document.getElementById('serverTypeSelect');
        if (select) {
            select.onchange = loadVersionsEnhanced;
        }
    }
});

function reinstallServer() {
    if (!confirm('Reinstall server? This will delete all server files except worlds and configs!')) return;
    if (!confirm('Are you absolutely sure? This action cannot be undone!')) return;
    
    showToast('info', '🔄 Starting server reinstallation...');
    
    fetch('/servers/<%= server.id %>/settings/reinstall', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
    })
    .then(res => {
        if (res.ok) {
            return res.json().catch(() => ({ success: true }));
        } else {
            return res.json().catch(() => ({ error: 'Server error' }));
        }
    })
    .then(data => {
        if (data.success !== false) {
            showToast('success', '✅ Server reinstalled successfully!');
            setTimeout(() => location.reload(), 1500);
        } else {
            showToast('error', '❌ Error: ' + (data.error || 'Failed to reinstall server'));
        }
    })
    .catch(err => {
        console.error('Error:', err);
        showToast('error', '❌ An error occurred during reinstallation');
    });
}

function deleteServer() {
    if (!confirm('DELETE THIS SERVER? All files will be permanently deleted!')) return;
    
    const confirmText = prompt('Type "<%= server.name %>" to confirm deletion:');
    if (confirmText !== '<%= server.name %>') {
        showToast('warning', '⚠️ Server name does not match. Deletion cancelled.');
        return;
    }
    
    showToast('info', '🗑️ Deleting server...');
    
    fetch('/servers/<%= server.id %>/delete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) {
            showToast('success', '✅ Server deleted successfully!');
            setTimeout(() => {
                window.location.href = '/dashboard';
            }, 1500);
        } else {
            showToast('error', '❌ Error: ' + (data.error || 'Failed to delete server'));
        }
    })
    .catch(err => {
        console.error('Error:', err);
        showToast('error', '❌ An error occurred during deletion');
    });
}

// Enhanced toast notification system (same as properties editor)
function showToast(type, message) {
    const toast = document.createElement('div');
    
    let bgColor, icon;
    if (type === 'success') {
        bgColor = 'linear-gradient(45deg, #28a745, #34ce57)';
        icon = 'fas fa-check-circle';
    } else if (type === 'error') {
        bgColor = 'linear-gradient(45deg, #dc3545, #e74c3c)';
        icon = 'fas fa-exclamation-circle';
    } else if (type === 'warning') {
        bgColor = 'linear-gradient(45deg, #ffc107, #ffcd39)';
        icon = 'fas fa-exclamation-triangle';
    } else {
        bgColor = 'linear-gradient(45deg, var(--primary), #3b82f6)';
        icon = 'fas fa-info-circle';
    }
    
    toast.style.cssText = `
        position: fixed;
        top: 20px;
        right: 20px;
        background: ${bgColor};
        color: white;
        padding: 16px 20px;
        border-radius: 12px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.3);
        z-index: 10001;
        max-width: 400px;
        font-size: 14px;
        font-weight: 500;
        animation: slideInRight 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        display: flex;
        align-items: center;
        gap: 12px;
        backdrop-filter: blur(10px);
    `;
    
    toast.innerHTML = `
        <i class="${icon}" style="font-size: 18px;"></i>
        <span>${message}</span>
        <button onclick="this.parentElement.remove()" style="
            background: none;
            border: none;
            color: white;
            font-size: 16px;
            cursor: pointer;
            margin-left: auto;
            opacity: 0.7;
            transition: opacity 0.2s ease;
        " onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.7'">
            <i class="fas fa-times"></i>
        </button>
    `;
    
    document.body.appendChild(toast);
    
    setTimeout(() => {
        if (toast.parentElement) {
            toast.style.animation = 'slideOutRight 0.4s ease';
            setTimeout(() => toast.remove(), 400);
        }
    }, 5000);
}

