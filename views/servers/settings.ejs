<div class="page-header">
    <div>
        <h1 class="page-title">
            <i class="fas fa-cog"></i>
            Server Settings
        </h1>
        <p class="page-subtitle"><%= server.name %></p>
    </div>
    <a href="/servers/<%= server.id %>/dashboard" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i>
        Back to Server
    </a>
</div>

<!-- General Settings -->
<div class="card">
    <div class="card-header">
        <h3>General Settings</h3>
    </div>
    <div class="card-body">
        <!-- Auto-Management Notice -->
        <div class="alert alert-info" style="margin-bottom: 20px;">
            <i class="fas fa-info-circle"></i>
            <strong>Smart Management:</strong> RAM allocation and server port are automatically managed by the system for optimal performance and security. You can configure these settings through the Properties editor.
        </div>
        
        <form onsubmit="saveSettings(event)">
            <div class="form-group">
                <label class="form-label">Server Name</label>
                <input type="text" name="name" class="form-control" value="<%= server.name %>" required>
            </div>

            <div class="form-group">
                <label class="form-label">Description</label>
                <textarea name="description" class="form-control" rows="3" placeholder="Optional server description"><%= server.description || '' %></textarea>
            </div>

            <button type="submit" class="btn btn-primary">
                <i class="fas fa-save"></i>
                Save Settings
            </button>
        </form>
    </div>
</div>

<!-- Server Information -->
<div class="card">
    <div class="card-header">
        <h3>Server Information</h3>
    </div>
    <div class="card-body">
        <div class="system-info-grid">
            <div class="info-item">
                <span class="info-label">Server ID</span>
                <span class="info-value">#<%= server.id %></span>
            </div>
            <div class="info-item">
                <span class="info-label">Server Type</span>
                <span class="info-value"><%= server.server_type || 'vanilla' %></span>
            </div>
            <div class="info-item">
                <span class="info-label">Version</span>
                <span class="info-value"><%= server.version || 'Latest' %></span>
            </div>
            <div class="info-item">
                <span class="info-label">RAM Allocation</span>
                <span class="info-value">
                    <%= server.ram %> MB
                    <span class="badge badge-info" style="margin-left: 8px; font-size: 10px;">AUTO-MANAGED</span>
                </span>
            </div>
            <div class="info-item">
                <span class="info-label">Server Port</span>
                <span class="info-value">
                    <%= server.port %>
                    <span class="badge badge-primary" style="margin-left: 8px; font-size: 10px;">PROTECTED</span>
                </span>
            </div>
            <div class="info-item">
                <span class="info-label">Status</span>
                <span class="info-value">
                    <span class="badge <%= server.status === 'running' ? 'badge-success' : 'badge-danger' %>">
                        <%= server.status %>
                    </span>
                </span>
            </div>
            <div class="info-item">
                <span class="info-label">Created</span>
                <span class="info-value"><%= new Date(server.created_at).toLocaleDateString() %></span>
            </div>
            <div class="info-item">
                <span class="info-label">Disk Usage</span>
                <span class="info-value"><%= typeof diskUsage !== 'undefined' ? diskUsage : 'Calculating...' %></span>
            </div>
        </div>
    </div>
</div>

<!-- Version Management -->
<div class="card">
    <div class="card-header">
        <h3><i class="fas fa-download"></i> Server Software & Version Management</h3>
    </div>
    <div class="card-body">
        <form id="softwareChangeForm" onsubmit="changeSoftware(event)">
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-server"></i>
                            Server Software
                        </label>
                        <select name="serverType" id="serverTypeSelect" class="form-control" onchange="loadVersions()" required>
                            <% Object.entries(serverSoftware).forEach(([category, softwares]) => { %>
                                <optgroup label="<%= category %>">
                                    <% softwares.forEach(software => { %>
                                        <option value="<%= software.key %>" 
                                                <%= server.server_type === software.key ? 'selected' : '' %>
                                                data-color="<%= software.color %>"
                                                data-icon="<%= software.icon %>">
                                            <%= software.name %> - <%= software.description %>
                                        </option>
                                    <% }) %>
                                </optgroup>
                            <% }) %>
                        </select>
                        <small class="form-text text-muted">
                            Current: <strong><%= server.server_type || 'vanilla' %></strong>
                        </small>
                    </div>
                </div>
                
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-tag"></i>
                            Minecraft Version
                        </label>
                        
                        <!-- Version Selection Mode Toggle -->
                        <div class="version-mode-toggle">
                            <button type="button" class="btn btn-sm btn-outline-primary active" onclick="toggleVersionMode('preset')" id="presetModeBtn">
                                <i class="fas fa-list"></i> Preset Versions
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-primary" onclick="toggleVersionMode('custom')" id="customModeBtn">
                                <i class="fas fa-edit"></i> Custom Version
                            </button>
                        </div>
                        
                        <!-- Preset Version Selection -->
                        <div id="presetVersionContainer">
                            <select name="version" id="versionSelect" class="form-control" required>
                                <option value="<%= server.version %>"><%= server.version %> (Current)</option>
                                <% if (typeof versions !== 'undefined' && versions && versions.length > 0) { %>
                                    <% versions.forEach(v => { %>
                                        <% if (v !== server.version) { %>
                                            <option value="<%= v %>"><%= v %></option>
                                        <% } %>
                                    <% }) %>
                                <% } %>
                            </select>
                            <small class="form-text text-muted">
                                <i class="fas fa-info-circle"></i>
                                Showing <span id="versionCount"><%= versions ? versions.length : 0 %></span> available versions
                            </small>
                        </div>
                        
                        <!-- Custom Version Input -->
                        <div id="customVersionContainer" style="display: none;">
                            <div class="input-group">
                                <input type="text" id="customVersionInput" class="form-control" 
                                       placeholder="Enter version (e.g., 1.20.1, 20w14a, latest)" 
                                       pattern="^(\d+\.\d+(\.\d+)?(-\w+)?|\d+w\d+[a-z]|latest|snapshot)$">
                                <div class="input-group-append">
                                    <button type="button" class="btn btn-outline-secondary" onclick="validateCustomVersion()">
                                        <i class="fas fa-check"></i> Validate
                                    </button>
                                </div>
                            </div>
                            <div id="customVersionFeedback" class="mt-2"></div>
                            <small class="form-text text-muted">
                                <i class="fas fa-lightbulb"></i>
                                <strong>Supported formats:</strong> 1.20.1, 1.19.4-pre1, 20w14a, latest, snapshot
                            </small>
                        </div>
                        
                        <small class="form-text text-muted mt-2">
                            Current: <strong><%= server.version %></strong>
                        </small>
                    </div>
                </div>
            </div>

            <!-- Software Information Display -->
            <div id="softwareInfo" class="software-info-card">
                <div class="software-info-content">
                    <div class="software-icon">
                        <i class="fas fa-cube" style="color: #8B4513;"></i>
                    </div>
                    <div class="software-details">
                        <h4 id="softwareName">Vanilla</h4>
                        <p id="softwareDescription">Official Minecraft server software from Mojang</p>
                        <div class="software-features" id="softwareFeatures">
                            <span class="feature-badge">plugins: false</span>
                            <span class="feature-badge">mods: false</span>
                            <span class="feature-badge">datapacks: true</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="alert alert-warning">
                <i class="fas fa-exclamation-triangle"></i>
                <span><strong>Important:</strong> Changing server software or version will require a server restart and may need additional setup. Always backup your server before making changes!</span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-sync-alt"></i>
                    Update Server Software
                </button>
                <button type="button" class="btn btn-info" onclick="showSoftwareGuide()">
                    <i class="fas fa-question-circle"></i>
                    Software Guide
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Danger Zone -->
<div class="card" style="border-color: var(--danger);">
    <div class="card-header" style="background: rgba(230, 57, 70, 0.1); border-color: var(--danger);">
        <h3 style="color: var(--danger);">
            <i class="fas fa-exclamation-triangle"></i>
            Danger Zone
        </h3>
    </div>
    <div class="card-body">
        <div style="margin-bottom: 20px;">
            <h4 style="font-size: 16px; margin-bottom: 8px;">Reinstall Server</h4>
            <p style="color: var(--text-secondary); font-size: 14px; margin-bottom: 12px;">
                Reinstall the server software. This will delete all server files except worlds and configs.
            </p>
            <button class="btn btn-warning" onclick="reinstallServer()">
                <i class="fas fa-redo"></i>
                Reinstall Server
            </button>
        </div>

        <div>
            <h4 style="font-size: 16px; margin-bottom: 8px; color: var(--danger);">Delete Server</h4>
            <p style="color: var(--text-secondary); font-size: 14px; margin-bottom: 12px;">
                Permanently delete this server and all its files. This action cannot be undone!
            </p>
            <button class="btn btn-danger" onclick="deleteServer()">
                <i class="fas fa-trash"></i>
                Delete Server
            </button>
        </div>
    </div>
</div>

<script>
function saveSettings(e) {
    e.preventDefault();
    const formData = new FormData(e.target);
    const data = Object.fromEntries(formData.entries());
    
    // Show loading state
    const btn = e.target.querySelector('button[type="submit"]');
    const originalText = btn.innerHTML;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving...';
    btn.disabled = true;
    
    fetch('/servers/<%= server.id %>/settings/update', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
    })
    .then(res => {
        if (res.ok) {
            return res.json().catch(() => ({ success: true })); // Handle redirect responses
        } else {
            return res.json().catch(() => ({ error: 'Server error' }));
        }
    })
    .then(data => {
        if (data.success !== false) {
            showToast('success', '✅ Settings saved successfully!');
            setTimeout(() => location.reload(), 1000);
        } else {
            showToast('error', '❌ Error: ' + (data.error || 'Failed to save settings'));
        }
    })
    .catch(err => {
        console.error('Error:', err);
        showToast('error', '❌ An error occurred while saving settings');
    })
    .finally(() => {
        btn.innerHTML = originalText;
        btn.disabled = false;
    });
}

function changeSoftware(e) {
    e.preventDefault();
    
    const serverType = e.target.serverType.value;
    let version;
    
    // Check which version mode is active
    if (currentVersionMode === 'custom') {
        version = document.getElementById('customVersionInput').value.trim();
        if (!customVersionValid) {
            showToast('error', '❌ Please validate your custom version first');
            return;
        }
    } else {
        version = e.target.version.value;
    }
    
    if (!version) {
        showToast('error', '❌ Please select or enter a version');
        return;
    }
    
    if (!confirm(`Change server software to ${serverType} ${version}? This will update the server configuration and may require additional setup. Make sure you have a backup!`)) return;
    
    const btn = e.target.querySelector('button[type="submit"]');
    const originalText = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Updating Software...';
    
    fetch('/servers/<%= server.id %>/settings/update', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
            name: '<%= server.name %>',
            description: '<%= server.description || "" %>',
            version: version,
            serverType: serverType
        })
    })
    .then(res => {
        if (res.ok) {
            return res.json().catch(() => ({ success: true }));
        } else {
            return res.json().catch(() => ({ error: 'Server error' }));
        }
    })
    .then(data => {
        if (data.success !== false) {
            showToast('success', '✅ Server software updated successfully! Restart the server to apply changes.');
            setTimeout(() => location.reload(), 1500);
        } else {
            showToast('error', '❌ Error: ' + (data.error || 'Failed to update server software'));
        }
    })
    .catch(err => {
        console.error('Error:', err);
        showToast('error', '❌ An error occurred while updating server software');
    })
    .finally(() => {
        btn.disabled = false;
        btn.innerHTML = originalText;
    });
}

// Load versions when server type changes
async function loadVersions() {
    const serverType = document.getElementById('serverTypeSelect').value;
    const versionSelect = document.getElementById('versionSelect');
    
    // Show loading state
    versionSelect.innerHTML = '<option>Loading versions...</option>';
    versionSelect.disabled = true;
    
    try {
        const response = await fetch(`/servers/<%= server.id %>/settings/versions/${serverType}`);
        const data = await response.json();
        
        if (data.success && data.versions) {
            versionSelect.innerHTML = '';
            data.versions.forEach(version => {
                const option = document.createElement('option');
                option.value = version;
                option.textContent = version;
                versionSelect.appendChild(option);
            });
            
            // Select the first version by default
            if (data.versions.length > 0) {
                versionSelect.value = data.versions[0];
            }
        } else {
            versionSelect.innerHTML = '<option>Error loading versions</option>';
        }
    } catch (err) {
        console.error('Error loading versions:', err);
        versionSelect.innerHTML = '<option>Error loading versions</option>';
    } finally {
        versionSelect.disabled = false;
    }
    
    // Update software info display
    updateSoftwareInfo(serverType);
}

